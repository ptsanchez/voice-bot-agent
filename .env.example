# OpenAI API key with Realtime API access
OPENAI_API_KEY=sk-...

# Realtime model to use (ex gpt-realtime-1.5 or gpt-realtime-2)
OPENAI_MODEL=gpt-realtime-1.5

# Twilio account credentials (from https://console.twilio.com)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# Your purchased Twilio phone number (E.164 format)
TWILIO_PHONE_NUMBER=+12223334444

# Target voice agent phone number to call
AGENT_PHONE_NUMBER=+18054398008

# ngrok auth token (from https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=...
